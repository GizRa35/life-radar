<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/risk_widget_bg">

    <!-- Üst satır: marka + hava -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="LIFE RADAR"
            android:textColor="#00B8D9"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"/>
        <TextView
            android:id="@+id/widget_weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#B0C4D4"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Risk puanı + seviye -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp">
        <TextView
            android:id="@+id/widget_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold"/>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Risk Puanı"
                android:textColor="#B0C4D4"
                android:textSize="10sp"/>
            <TextView
                android:id="@+id/widget_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#00B8D9"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Ayraç -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="7dp"
        android:background="#22FFFFFF"/>

    <!-- Son deprem -->
    <TextView
        android:id="@+id/widget_quake"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="—"
        android:textColor="#E6EEF5"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- Günün uyarısı -->
    <TextView
        android:id="@+id/widget_alert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="—"
        android:textColor="#9FB3C4"
        android:textSize="10sp"
        android:maxLines="2"
        android:ellipsize="end"/>
</LinearLayout>
